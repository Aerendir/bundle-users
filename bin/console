use SerendipityHQ\Bundle\UsersBundle\Tests\Fixtures\App\SHQBundleUsersTestKernel;
use Symfony\Bundle\FrameworkBundle\Console\Application;
use Symfony\Component\Console\Input\ArgvInput;
use Symfony\Component\Dotenv\Dotenv;

if (false === \is_file(\dirname(__DIR__).'/vendor/autoload.php')) {
    throw new LogicException('Run "composer install" to allow executing the console.');
}

require \dirname(__DIR__).'/vendor/autoload.php';

if (class_exists(Dotenv::class) && is_file($env = \dirname(__DIR__).'/.env')) {
    (new Dotenv())->load($env);
}

$input = new ArgvInput();
$env = $input->getParameterOption(['--env', '-e'], $_SERVER['APP_ENV'] ?? 'test', true);
$debug = $_SERVER['APP_DEBUG'] ?? ('prod' !== $env);

$kernel = new SHQBundleUsersTestKernel($env, (bool) $debug);
$application = new Application($kernel);
$application->run($input);
